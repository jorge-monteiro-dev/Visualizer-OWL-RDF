  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#MalignantBreastMyoepithelioma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An invasive malignant tumor that arises from the breast.  It is characterized by the presence of spindle-shaped myoepithelial cells.  Mitoses are present.  Rarely, local recurrences and distant metastases have been reported."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C40395"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Malignant Breast Myoepithelioma"
  } ],
