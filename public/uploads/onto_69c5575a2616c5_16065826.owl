}, {
  "@id" : "http://desiree-project.eu/bckm#MedullaryBreastCarcinoma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A rare type of breast cancer that often can be treated successfully. It is marked by lymphocytes (a type of white blood cell) in and around the tumor that can be seen when viewed under a microscope."
  } ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An infiltrating breast carcinoma with a relatively favorable prognosis.  It is an uncommon carcinoma, accounting for less than 1% of all infiltrating breast carcinomas.  It is well circumscribed, with soft cut surface and often of considerable size.  Microscopically, the predominant growth pattern is syncytial with broad anastomosing bands or sheets of malignant cells.  The malignant cells are round with abundant cytoplasm and vesicular nuclei.  The sheets of malignant cells are associated with a marked lymphoplasmacytic infiltrate.  Glandular or tubular structures are absent."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C9119"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Medullary Breast Carcinoma"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C0860580"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Medullary Breast Carcinoma"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinomaSpecified"
  } ]
