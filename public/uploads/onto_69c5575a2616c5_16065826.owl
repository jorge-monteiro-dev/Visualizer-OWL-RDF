}, {
  "@id" : "http://desiree-project.eu/bckm#HomogeneousFibroglandularEchotexture",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A uniformly echogenic layer of fibroglandular tissue is seen beneath a thin layer of subcutaneous fat."
