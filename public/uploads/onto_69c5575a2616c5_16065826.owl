  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#SquamousCellBreastCarcinomaAcantholyticVariant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A squamous cell carcinoma that arises from the breast parenchyma and is characterized by cellular discohesion resulting in a pseudoangiosarcomatous pattern."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C40359"
  } ],
