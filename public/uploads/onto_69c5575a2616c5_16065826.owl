    "@id" : "http://desiree-project.eu/bckm#SquamousCellBreastCarcinoma"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#SquamousCellBreastCarcinomaSpindleCellVariant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A squamous cell carcinoma that arises from the breast parenchyma and is characterized by the presence of spindle-shaped malignant cells."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C40358"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Squamous Cell Breast Carcinoma, Spindle Cell Variant"
  } ],
