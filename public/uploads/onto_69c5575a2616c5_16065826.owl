}, {
  "@id" : "http://desiree-project.eu/bckm#ModifiedRadicalMastectomy",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "Surgery for breast cancer in which the breast, most or all of the lymph nodes under the arm, and the lining over the chest muscles are removed. Sometimes the surgeon also removes part of the chest wall muscles."
  } ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "The surgical removal of one or both breasts, including the areola, nipple, and the majority of the axillary lymph nodes, but sparing the pectoralis major muscle."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C15278"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Modified Radical Mastectomy"
  } ],
