}, {
  "@id" : "http://desiree-project.eu/bckm#Ac-t-tRegimen",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An abbreviation for a chemotherapy combination used to treat breast cancer. It includes the drugs doxorubicin hydrochloride (Adriamycin) and cyclophosphamide, followed by treatment with paclitaxel (Taxol) and trastuzumab (Herceptin)."
  } ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A regimen consisting of cyclophosphamide and doxorubicin, followed by paclitaxel and trastuzumab, administered in a sequential fashion and used as an adjuvant treatment for HER-2/neu-positive breast cancer."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C63425"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "AC-T-T Regimen"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C1879499"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "AC-T-T Regimen"
  } ],
