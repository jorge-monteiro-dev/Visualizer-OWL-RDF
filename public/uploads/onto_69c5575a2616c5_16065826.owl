    "@language" : "en",
    "@value" : "C1334206"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Intermediate Grade Ductal Breast Carcinoma In Situ"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
