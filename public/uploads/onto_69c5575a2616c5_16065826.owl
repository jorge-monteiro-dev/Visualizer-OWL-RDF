  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#otherObjectProperty"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#hasVariable",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Should become obsolete\nOne should use the isAttributeOf relation instead (which is some kind of inverse relation) by which each variable is linked to an entity which could be either PatienEntity, SideEntity or LesionEntity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#otherObjectProperty"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#isAttributeOf",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This property establish a link between any variable and the entity to which it refers ( PatientEntity,SideEntity LesionEntity).\nIt allows a variable classification via equivalent classes ."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://desiree-project.eu/bckm#DESIREEAttribute"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://desiree-project.eu/bckm#DESIREEEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#CDSObjectProperty"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#isPartOf",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The two subproperties expresses the compositional links between the 3 main BreastCancerEntities.\nIt allows to declare several Lesions on the same side of the same patient for example in order to deal with multifocality."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://desiree-project.eu/bckm#DESIREEEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://desiree-project.eu/bckm#DESIREEEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#CDSObjectProperty"
  } ]
