  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#SquamousCellBreastCarcinomaLargeCellKeratinizingVariant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A squamous cell carcinoma that arises from the breast parenchyma and is characterized by the presence of large malignant cells that exhibit keratinization."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C40357"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Squamous Cell Breast Carcinoma, Large Cell Keratinizing Variant"
  } ],
