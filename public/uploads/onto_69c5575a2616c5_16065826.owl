  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "The removal of a cancer as well as some of the breast tissue around the tumor and the lining over the chest muscles below the tumor. Usually some of the lymph nodes under the arm are also taken out."
  } ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "The removal of a cancer as well as some of the breast tissue around the tumor and the lining over the chest muscles below the tumor. Usually some of the lymph nodes under the arm are also taken out. Also called partial mastectomy. (Cancer.gov)"
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C20749"
  } ],
