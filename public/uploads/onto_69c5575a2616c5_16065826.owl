}, {
  "@id" : "http://desiree-project.eu/bckm#BreastCarcinoma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A malignant neoplasm that develops or arises in breast tissue.,Cancer that forms in tissues of the breast, usually the ducts (tubes that carry milk to the nipple) and lobules (glands that make milk). It occurs in both men and women, although male breast cancer is rare."
  } ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A carcinoma arising from the breast, most commonly the terminal ductal-lobular unit. It is the most common malignant tumor in females. Risk factors include country of birth, family history, menstrual and reproductive history, fibrocystic disease and epithelial hyperplasia, exogenous estrogens, contraceptive agents, and ionizing radiation. The vast majority of breast carcinomas are adenocarcinomas (ductal or lobular). Breast carcinoma spreads by direct invasion, by the lymphatic route, and by the blood vessel route. The most common site of lymph node involvement is the axilla."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C4872"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Breast Carcinoma"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C0678222"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Breast Carcinoma"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#DomainConcept"
  } ]
