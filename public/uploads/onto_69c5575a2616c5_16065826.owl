    "@language" : "en",
    "@value" : "This property establish a bridge between ComplexTypes and some SimpleType used in the definition of this Complextype"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://desiree-project.eu/bckm#CompositeValue"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#otherObjectProperty"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#hasTechnique",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#otherObjectProperty"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#hasTreatment",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#otherObjectProperty"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#hasUnit",
