    "@id" : "http://desiree-project.eu/bckm#Anthracycline-taxane-basedChemotherapyRegimen"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#Ac-tRegimen",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An abbreviation for a chemotherapy combination used to treat breast cancer. It includes the drugs doxorubicin hydrochloride (Adriamycin) and cyclophosphamide, followed by treatment with paclitaxel (Taxol)."
  } ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A chemotherapy regimen consisting of doxorubucin hydrochloride (Adriamycin) and cyclophosphamide, followed by paclitaxel (Taxol), administered on either a dose-dense or sequential schedule and used as an adjuvant treatment for breast cancer."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C63427"
  } ],
