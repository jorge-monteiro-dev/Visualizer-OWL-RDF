  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "All the subproperties of this one allows to assign a value to an instance of some variable when these values are some primitive OWL datatype.\nThes subProperties are shared by all the variables of any kind."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://desiree-project.eu/bckm#DESIREEAttribute"
  } ],
