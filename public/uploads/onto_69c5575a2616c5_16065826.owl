  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#BreastCarcinomaWithChoriocarcinomatousFeatures",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An invasive ductal breast carcinoma, not otherwise specified, characterized by increased levels of human beta-chorionic gonadotropin in the serum.  Morphologic evidence of choriocarcinomatous differentiation is rare."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C40350"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Breast Carcinoma with Choriocarcinomatous Features"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C1511302"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Breast Carcinoma with Choriocarcinomatous Features"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinomaNOS"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#BreastCarcinomaWithMelanoticFeatures",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A very rare primary malignant tumor of the breast, characterized by an invasive breast carcinoma that co-exists with a melanoma component.  The vast majority of melanotic tumors that affect the breast are metastatic melanomas that originate in extra-mammary sites."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C40351"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Breast Carcinoma with Melanotic Features"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C1511303"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Breast Carcinoma with Melanotic Features"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinomaNOS"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#BreastCarcinomaWithOsseousMetaplasia",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An invasive breast carcinoma showing differentiation towards bone structures."
