  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C1711312"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Breast Carcinoma with Osseous Metaplasia"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#MixedEpithelial/mesenchymalMetaplasticBreastCarcinoma"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#BreastCarcinomaWithOsteoclasticGiantCells",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An invasive breast adenocarcinoma characterised by the presence of non-neoplastic stromal osteoclastic giant cells.  The carcinomatous component is usually an invasive ductal carcinoma, although all other breast adenocarcinoma subtypes have also been described.  The prognosis depends on the characteristics of the adenocarcinomatous component, and is not related to the presence of the giant cells."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C40349"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Breast Carcinoma with Osteoclastic Giant Cells"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C1511304"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Breast Carcinoma with Osteoclastic Giant Cells"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveNonDuctalNonLobularCarcinoma?"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#BreastColumnarCellMucinousCarcinoma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An invasive breast adenocarcinoma characterized by the presence of tall columnar neoplastic cells that contain intracytoplasmic mucin.  Grossly, cystic changes are not identified."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C40355"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Breast Columnar Cell Mucinous Carcinoma"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C1511305"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Breast Columnar Cell Mucinous Carcinoma"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveNonDuctalNonLobularCarcinoma?"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#BreastConservationTreatment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An operation to remove the breast cancer but not the breast itself. Types of breast-conserving surgery include lumpectomy (removal of the lump), quadrantectomy (removal of one quarter of the breast), and segmental mastectomy (removal of the cancer as well as some of the breast tissue around the tumor and the lining over the chest muscles below the tumor)."
  } ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "Breast conservation treatment is defined as excision of the primary tumor and adjacent breast tissue, followed by radiation therapy.  This procedure is also referred to as lumpectomy, segmental mastectomy, or partial mastectomy. (from Consensus Statements: Treatment of Early-stage Breast Cancer, 1990)"
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C15280"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Breast Conservation Treatment"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
