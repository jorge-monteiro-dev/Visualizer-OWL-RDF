}, {
  "@id" : "http://desiree-project.eu/bckm#IntermediateGradeDuctalBreastCarcinomaInSitu",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "Ductal breast carcinoma in situ characterized by the presence of monomorphic neoplastic cells that form cribriform, micropapillary, or solid patterns. Intraluminal necrosis is present in some ducts. Ducts that contain neoplastic cells with occasional nucleoli and coarse chromatin may also be present."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C9456"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Intermediate Grade Ductal Breast Carcinoma In Situ"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
