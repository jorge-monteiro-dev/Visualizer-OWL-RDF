}, {
  "@id" : "http://desiree-project.eu/bckm#AtypicalMedullaryBreastCarcinoma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An invasive ductal breast carcinoma characterized by the presence of a predominantly syncytial architectural pattern. It may have some, but not all the strictly defined additional morphologic criteria which are necessary for the diagnosis of medullary breast carcinoma (presence of a diffuse lymphoplasmacytic infiltrate, neoplastic round cells with abundant cytoplasm and vesicular nuclei, complete histological circumscription, and absence of glandular or tubular structures). It does not have the relatively favorable outcome that characterizes medullary breast carcinoma."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C66719"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Atypical Medullary Breast Carcinoma"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C1879758"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Atypical Medullary Breast Carcinoma"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinomaSpecified"
  } ]
