  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#InflammatoryBreastCarcinoma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A type of breast cancer in which the breast looks red and swollen and feels warm. The skin of the breast may also show the pitted appearance called peau d'orange (like the skin of an orange). The redness and warmth occur because the cancer cells block the lymph vessels in the skin."
  } ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An advanced, invasive breast adenocarcinoma characterized by the presence of distinct changes in the overlying skin. These changes include diffuse erythema, edema, peau d'orange (skin of an orange) appearance, tenderness, induration, warmth, enlargement, and in some cases a palpable mass. The skin changes are the consequence of lymphatic obstruction from the underlying invasive breast adenocarcinoma. Microscopically, the dermal lymphatics show prominent infiltration by malignant cells. The invasive breast adenocarcinoma is usually of ductal, NOS type. There is not significant inflammatory cell infiltrate present, despite the name of this carcinoma."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C4001"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Inflammatory Breast Carcinoma"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C0278601"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Inflammatory Breast Carcinoma"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveNonDuctalNonLobularCarcinoma?"
  } ]
