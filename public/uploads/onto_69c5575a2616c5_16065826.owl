    "@language" : "fr",
    "@value" : "Intraductal Papillary Adenocarcinoma with Invasion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasivePapillaryBreastCarcinoma"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#InvasiveApocrineBreastCarcinoma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An invasive breast adenocarcinoma with cytological and immunophenotypic characteristics of apocrine differentiation in more than 90 percent of the malignant cells."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C5457"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Invasive Apocrine Breast Carcinoma"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C1334272"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Invasive Apocrine Breast Carcinoma"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinomaSpecified"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#InvasiveBreastCarcinoma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "Cancer that has spread from where it started in the breast into surrounding, healthy tissue. Most invasive breast cancers start in the ducts (tubes that carry milk from the lobules to the nipple). Invasive breast cancer can spread to other parts of the body through the blood and lymph systems."
  } ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A carcinoma that infiltrates the breast parenchyma.  The vast majority are adenocarcinomas arising from the terminal ductal lobular unit (TDLU).  Often, the invasive adenocarcinoma co-exists with ductal or lobular carcinoma in situ.  It is the most common carcinoma affecting women."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C9245"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Invasive Breast Carcinoma"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C0853879"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Invasive Breast Carcinoma"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#BreastCarcinoma"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinoma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Not in NCIt"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Invasive Ductal Carcinoma"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveNonLobularBreastCarcinoma"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinomaNOS",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "The most common type of invasive breast cancer. It starts in the cells that line the milk ducts in the breast, grows outside the ducts, and often spreads to the lymph nodes."
  } ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "The most common type of invasive breast carcinoma, accounting for approximately 70% of breast carcinomas.  The gross appearance is usually typical with an irregular stellate outline.  Microscopically, randomly arranged epithelial elements are seen.  When large sheets of malignant cells are present, necrosis may be seen.  With adequate tissue sampling, in situ carcinoma can be demonstrated in association with the infiltrating carcinoma.  The in situ component is nearly always ductal but occasionally may be lobular or both."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C4194"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Invasive Ductal Carcinoma, Not Otherwise Specified"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C1134719"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Invasive Ductal Carcinoma Not Otherwise Specified"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinoma"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinomaSpecified",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Not in NCIt"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Invasive Ductal Carcinoma, With Special Features"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinoma"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinomaWithPredominantIntraductalComponent",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A breast carcinoma characterized by the presence of a predominant ductal carcinoma in situ component and a minor component of invasive carcinoma."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C9132"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Invasive Ductal Breast Carcinoma with Predominant Intraductal Component"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C0279556"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Invasive Ductal Breast Carcinoma with Predominant Intraductal Component"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveDuctalBreastCarcinomaNOS"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#InvasiveLobularBreastCarcinoma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An infiltrating lobular adenocarcinoma of the breast.  The malignant cells lack cohesion and are arranged individually or in a linear manner (Indian files), or as narrow trabeculae within the stroma.  The malignant cells are usually smaller than those of ductal carcinoma, are less pleomorphic, and have fewer mitotic figures."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C7950"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Invasive Lobular Breast Carcinoma"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C0279565"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Invasive Lobular Breast Carcinoma"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveBreastCarcinoma"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#InvasiveLobularBreastCarcinomaAlveolarVariant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A grade I invasive lobular carcinoma of the breast, characterized by the presence of round groups of neoplastic cells."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
    "@value" : "C97049"
  } ],
  "http://desiree-project.eu/bckm#NCI_label" : [ {
    "@language" : "en",
    "@value" : "Invasive Lobular Breast Carcinoma, Alveolar Variant"
  } ],
  "http://desiree-project.eu/bckm#NCI_version" : [ {
    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C3273215"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Invasive Lobular Breast Carcinoma, Alveolar Variant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#InvasiveLobularBreastCarcinoma"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#InvasiveLobularBreastCarcinomaPleomorphicVariant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
