}, {
  "@id" : "http://desiree-project.eu/bckm#BreastCarcinomaWithChondroidMetaplasia",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "An invasive carcinoma of the breast showing differentiation towards cartilaginous structures."
