  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "Ductal breast carcinoma in situ characterized by the presence of small, monomorphic neoplastic cells that form cribriform, micropapillary, or solid patterns. The nuclei are uniform and mitotic figures are rare."
  } ],
