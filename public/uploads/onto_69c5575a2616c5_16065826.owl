    "@language" : "en",
    "@value" : "17.06d"
  } ],
  "http://desiree-project.eu/bckm#UMLS_CUI" : [ {
    "@language" : "en",
    "@value" : "C1519486"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Squamous Cell Breast Carcinoma, Large Cell Keratinizing Variant"
