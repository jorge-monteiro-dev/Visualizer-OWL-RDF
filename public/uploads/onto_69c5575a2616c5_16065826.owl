  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://desiree-project.eu/bckm#BreastConservationTreatment"
  } ]
}, {
  "@id" : "http://desiree-project.eu/bckm#LymphNodeBiopsy",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "A test in which a lymph node or a piece of a lymph node is removed for examination under a microscope for signs of infection or disease such as cancer."
  } ],
  "http://desiree-project.eu/bckm#NCI_code" : [ {
    "@language" : "en",
