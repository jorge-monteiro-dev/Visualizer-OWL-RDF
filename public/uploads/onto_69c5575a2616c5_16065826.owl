  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://desiree-project.eu/bckm#NCI_ALT_DEFINITION" : [ {
    "@language" : "en",
    "@value" : "Describes cells that do not have a protein to which the hormone progesterone will bind. Cancer cells that are progesterone receptor negative do not need progesterone to grow, and usually do not stop growing when treated with hormones that block progesterone from binding."
  } ],
